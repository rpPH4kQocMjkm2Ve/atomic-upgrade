#!/bin/bash
# /usr/bin/atomic-guard
#
# Pacman hook guard: blocks direct system upgrades.
# Allows upgrades only when called from atomic-upgrade (via env + lock)
# or from AUR helpers (yay, paru, etc.) which invoke pacman themselves.
# Note: no "set -euo pipefail" here — the script relies on conditional
# checks and process-tree walking that would break with errexit.

readonly LIBDIR="/usr/lib/atomic"

# Load common.sh with graceful degradation
_COMMON_LOADED=0
if _p=$(verify-lib "${LIBDIR}/common.sh" "$LIBDIR/" 2>/dev/null) && [[ -n "$_p" ]]; then
    if source "$_p" 2>/dev/null; then
        _COMMON_LOADED=1
    fi
fi

case "${1:-}" in
    -V|--version) echo "atomic-guard v${VERSION:-unknown}"; exit 0 ;;
esac

LOCK_DIR="${LOCK_DIR:-/run/atomic}"
LOCK_FILE="${LOCK_FILE:-${LOCK_DIR}/atomic-upgrade.lock}"

# If guard is disabled in config, allow everything
if [[ "${UPGRADE_GUARD:-1}" == "0" ]]; then
    exit 0
fi

# If called during atomic-upgrade: verify lock is actually held
if [[ "${ATOMIC_UPGRADE:-}" == "1" ]]; then
    [[ -f "$LOCK_FILE" ]] || exit 1
    # If we CAN acquire the lock, nobody holds it — that's wrong
    flock -n "$LOCK_FILE" -c true 2>/dev/null && exit 1
    exit 0
fi

# ── Sysupgrade detection ────────────────────────────────────────
is_sysupgrade() {
    local pid=$$
    while [[ $pid -ne 1 ]]; do
        local comm
        comm=$(cat "/proc/$pid/comm" 2>/dev/null) || break
        if [[ "$comm" == "pacman" ]]; then
            local has_sync=0 has_upgrade=0 arg
            while IFS= read -r -d '' arg; do
                [[ "$arg" == "--sync" ]] && has_sync=1
                [[ "$arg" == "--sysupgrade" ]] && has_upgrade=1
                if [[ "$arg" =~ ^-[^-] ]]; then
                    [[ "$arg" == *S* ]] && has_sync=1
                    [[ "$arg" == *u* ]] && has_upgrade=1
                fi
            done < "/proc/$pid/cmdline"
            [[ $has_sync -eq 1 && $has_upgrade -eq 1 ]] && return 0
            return 1
        fi
        pid=$(awk '/^PPid:/{print $2}' "/proc/$pid/status" 2>/dev/null) || break
    done
    echo "atomic-guard: pacman not found in process tree, blocking" >&2
    return 0
}

if ! is_sysupgrade; then
    exit 0
fi

# Allow AUR helpers — walk up the process tree via /proc
if [[ $_COMMON_LOADED -eq 1 ]]; then
    if type -t is_child_of_aur_helper &>/dev/null && is_child_of_aur_helper; then
        echo -e "\033[33mNOTE: AUR helper sysupgrade runs on live system (not atomic)\033[0m" >&2
        echo -e "\033[33m      For atomic upgrades use: sudo atomic-upgrade\033[0m" >&2
        exit 0
    fi
else
    # Fallback: inline AUR helper check when common.sh failed to load
    _check_aur_helper() {
        local pid=$$
        while [[ $pid -ne 1 ]]; do
            local comm
            comm=$(cat "/proc/$pid/comm" 2>/dev/null) || break
            case "$comm" in
                yay|paru|pikaur|aura) return 0 ;;
            esac
            pid=$(awk '/^PPid:/{print $2}' "/proc/$pid/status" 2>/dev/null) || break
        done
        return 1
    }
    if _check_aur_helper; then
        echo -e "\033[33mNOTE: AUR helper sysupgrade runs on live system (not atomic)\033[0m" >&2
        echo -e "\033[33m      For atomic upgrades use: sudo atomic-upgrade\033[0m" >&2
        exit 0
    fi
fi

cat << 'EOF'
════════════════════════════════════════════════════════════════
  Direct upgrade blocked. Use: sudo atomic-upgrade
════════════════════════════════════════════════════════════════
EOF
exit 1
